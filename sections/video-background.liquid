{% if section.settings.show_section %}
<div class="rruga-video-section" id="rruga-video-{{ section.id }}" style="position:relative;overflow:hidden;width:100%;">
  <style>
    #rruga-video-{{ section.id }} {
      height: calc({{ section.settings.section_height }}vh - var(--header-height, 0px));
    }
    @media screen and (max-width: 749px) {
      #rruga-video-{{ section.id }} {
        height: calc({{ section.settings.section_height_mobile }}vh - var(--header-height, 0px)) !important;
      }
    }
  </style>
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const nav = document.querySelector('.rruga-nav');
      if (nav) {
        const navHeight = nav.offsetHeight + 'px';
        document.documentElement.style.setProperty('--header-height', navHeight);
      }
    });
  </script>
  {% if section.settings.video_url != blank %}
    {% assign video_url = section.settings.video_url %}
    {% if video_url contains 'youtube.com' or video_url contains 'youtu.be' %}
      {% assign video_id = video_url | split: 'v=' | last | split: '&' | first %}
      {% if video_url contains 'youtu.be' %}
        {% assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first %}
      {% endif %}
      <iframe
        src="https://www.youtube.com/embed/{{ video_id }}?autoplay=1&mute=1&loop=1&playlist={{ video_id }}&controls=0&showinfo=0&modestbranding=1&playsinline=1"
        style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:{{ section.settings.video_scale }}%;height:{{ section.settings.video_scale }}%;border:none;pointer-events:none;"
        allow="autoplay; fullscreen"
        frameborder="0">
      </iframe>
    {% elsif video_url contains 'vimeo.com' %}
      {% assign video_id = video_url | split: 'vimeo.com/' | last | split: '?' | first %}
      <iframe
        src="https://player.vimeo.com/video/{{ video_id }}?autoplay=1&muted=1&loop=1&background=1&controls=0"
        style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:{{ section.settings.video_scale }}%;height:{{ section.settings.video_scale }}%;border:none;pointer-events:none;"
        allow="autoplay; fullscreen"
        frameborder="0">
      </iframe>
    {% else %}
      <video
        autoplay muted loop playsinline
        style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:{{ section.settings.video_scale }}%;height:{{ section.settings.video_scale }}%;object-fit:cover;">
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      </video>
    {% endif %}
  {% endif %}

  {% if section.settings.fallback_image != blank %}
  <div class="rruga-video__fallback" id="fallback-{{ section.id }}" style="
    position:absolute;top:0;left:0;width:100%;height:100%;
    background-image:url('{{ section.settings.fallback_image | img_url: '2000x' }}');
    background-size:cover;
    background-position:center;
    display:none;
  "></div>
  {% endif %}

  {% if section.settings.overlay_show %}
  <div style="
    position:absolute;top:0;left:0;width:100%;height:100%;
    background:{{ section.settings.overlay_color }};
    opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};
  "></div>
  {% endif %}

  {% if section.settings.text != blank %}
  <div style="
    position:absolute;
    top:50%;left:50%;
    transform:translate(-50%,-50%);
    color:{{ section.settings.text_color }};
    font-family:'Space Mono',monospace;
    font-size:{{ section.settings.text_size }}px;
    text-transform:uppercase;
    text-align:center;
    z-index:2;
    pointer-events:none;
  ">{{ section.settings.text }}</div>
  {% endif %}

  <script>
  (function() {
    const section = document.getElementById('rruga-video-{{ section.id }}');
    const fallback = document.getElementById('fallback-{{ section.id }}');
    const video = section ? section.querySelector('video') : null;
    const iframe = section ? section.querySelector('iframe') : null;

    if (video) {
      video.play().catch(function() {
        if (fallback) fallback.style.display = 'block';
      });
    } else if (iframe) {
      if (navigator.userAgent.match(/iPhone|iPad/i)) {
        setTimeout(function() {
          if (fallback) fallback.style.display = 'block';
        }, 2000);
      }
    }
  })();
  </script>
</div>
{% endif %}

{% schema %}
{
  "name": "Video Background",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_section",
      "label": "Show section",
      "default": true
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL",
      "info": "Supports YouTube, Vimeo or direct MP4 link"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section height (vh)",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 100
    },
    {
      "type": "range",
      "id": "section_height_mobile",
      "label": "Section height mobile (vh)",
      "min": 20,
      "max": 100,
      "step": 5,
      "default": 50
    },
    {
      "type": "range",
      "id": "video_scale",
      "label": "Video scale (%)",
      "min": 100,
      "max": 300,
      "step": 10,
      "default": 170
    },
    {
      "type": "checkbox",
      "id": "overlay_show",
      "label": "Show overlay",
      "default": false
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay opacity (%)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 40
    },
    {
      "type": "text",
      "id": "text",
      "label": "Overlay text"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size (px)",
      "min": 8,
      "max": 80,
      "step": 2,
      "default": 14
    },
    {
      "type": "image_picker",
      "id": "fallback_image",
      "label": "Fallback image (shown when video can't play)"
    },
    {
      "type": "color",
      "id": "play_button_color",
      "label": "Play button color",
      "default": "#ffffff"
    }
  ],
  "presets": [{ "name": "Video Background" }]
}
{% endschema %}
