<div id="rruga-preloader">
  <div class="rruga-preloader__inner">
    {% if section.settings.preloader_logo != blank %}
      <img src="{{ section.settings.preloader_logo | img_url: '300x' }}" alt="logo" class="rruga-preloader__logo">
    {% else %}
      <div class="rruga-preloader__text">{{ section.settings.preloader_text | default: 'RRUGA STUDIOS' }}</div>
    {% endif %}
  </div>
</div>

<style>
#rruga-preloader {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: {{ section.settings.preloader_bg | default: '#000000' }};
  z-index: 99999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.rruga-preloader__text {
  color: {{ section.settings.preloader_color | default: '#ffffff' }};
  font-family: 'Space Mono', monospace;
  font-size: 14px;
  text-transform: uppercase;
  animation: glitch 1.5s ease forwards;
}
.rruga-preloader__logo {
  animation: glitch 1.5s ease forwards;
  max-width: 200px;
}
@keyframes glitch {
  0% { opacity: 0; transform: skewX(0deg); clip-path: inset(0 0 100% 0); }
  10% { opacity: 1; transform: skewX(-5deg); clip-path: inset(20% 0 40% 0); }
  20% { transform: skewX(5deg); clip-path: inset(60% 0 10% 0); }
  30% { transform: skewX(-3deg); clip-path: inset(0 0 0 0); }
  50% { transform: skewX(0deg); opacity: 1; }
  100% { transform: skewX(0deg); opacity: 1; }
}
#rruga-preloader.fade-out {
  opacity: 0;
  transition: opacity 0.6s ease;
  pointer-events: none;
}
</style>

<script>
window.addEventListener('load', function() {
  setTimeout(function() {
    const preloader = document.getElementById('rruga-preloader');
    preloader.classList.add('fade-out');
    setTimeout(function() { preloader.style.display = 'none'; }, 600);
  }, {{ section.settings.preloader_duration | default: 1800 }});
});
</script>
