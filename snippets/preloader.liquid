<div id="rruga-preloader">
  <div class="rruga-preloader__inner">
    {% if section.settings.preloader_logo != blank %}
      <img src="{{ section.settings.preloader_logo | image_url: width: 600 }}" alt="logo" class="rruga-preloader__logo" width="{{ section.settings.logo_width }}" height="auto" style="width: {{ section.settings.logo_width }}px;">
    {% else %}
      <div class="rruga-preloader__text">{{ section.settings.preloader_text | default: 'RRUGA STUDIOS' }}</div>
    {% endif %}
  </div>
</div>

<style>
#rruga-preloader {
  position: fixed;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: {{ section.settings.preloader_bg | default: '#000000' }};
  z-index: 99999;
  display: flex;
  align-items: center;
  justify-content: center;
}
.rruga-preloader__text {
  color: {{ section.settings.preloader_color | default: '#ffffff' }};
  font-family: 'Space Mono', monospace;
  font-size: 14px;
  text-transform: uppercase;
  animation: fadeIn 1s ease forwards;
}
.rruga-preloader__logo {
  animation: fadeIn 1s ease forwards;
  height: auto;
}
@keyframes fadeIn {
  0% { opacity: 0; }
  100% { opacity: 1; }
}
#rruga-preloader.fade-out {
  opacity: 0;
  transition: opacity 0.6s ease;
  pointer-events: none;
}
</style>

<script>
window.addEventListener('load', function() {
  setTimeout(function() {
    const preloader = document.getElementById('rruga-preloader');
    preloader.classList.add('fade-out');
    setTimeout(function() { preloader.style.display = 'none'; }, 600);
  }, {{ section.settings.preloader_duration | default: 1800 }});
});
</script>
