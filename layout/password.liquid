<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }}</title>
  {{ content_for_header }}
  <link rel="stylesheet" href="{{ 'base.css' | asset_url }}">
  <style>
    body {
      margin: 0;
      padding: 0;
      background: #000000;
      color: #ffffff;
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      text-transform: uppercase;
      height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
    }

    .password-logo {
      margin-bottom: 40px;
    }

    .password-logo img {
      width: 150px;
      height: auto;
    }

    .password-logo span {
      font-size: 14px;
      letter-spacing: 0;
    }

    .password-message {
      margin-bottom: 40px;
      opacity: 0.6;
    }

    .password-form {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 10px;
      width: 300px;
    }

    .password-form input {
      width: 100%;
      background: #000000;
      border: 1px solid #ffffff;
      color: #ffffff;
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      text-transform: uppercase;
      padding: 10px;
      box-sizing: border-box;
      outline: none;
    }

    .password-form input::placeholder {
      color: rgba(255,255,255,0.4);
    }

    .password-form button {
      width: 100%;
      background: #ffffff;
      color: #000000;
      border: none;
      font-family: 'Space Mono', monospace;
      font-size: 11px;
      text-transform: uppercase;
      padding: 10px;
      cursor: pointer;
    }

    .password-form button:hover {
      background: #cccccc;
    }
  </style>
</head>
<body>
  <div class="password-logo">
    {% if settings.logo %}
      <img src="{{ settings.logo | img_url: '300x' }}" alt="{{ shop.name }}">
    {% else %}
      <span>{{ shop.name }}</span>
    {% endif %}
  </div>

  <div class="password-message">COMING SOON</div>

  <form class="password-form" action="/password" method="post">
    <input type="password" name="password" placeholder="ENTER PASSWORD">
    <button type="submit">ENTER</button>
  </form>

  {{ content_for_layout }}
</body>
</html>
